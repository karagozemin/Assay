{
  "name": "assay-backend",
  "private": true,
  "type": "module",
  "description": "Assay backend: Source Registry + x402 seller middleware + append-only ledger + traction metrics.",
  "scripts": {
    "dev": "node --experimental-transform-types --experimental-sqlite --no-warnings --env-file=.env.local --watch src/server.ts",
    "start": "node --experimental-transform-types --experimental-sqlite --no-warnings --env-file=.env.local src/server.ts",
    "seed": "node --experimental-transform-types --experimental-sqlite --no-warnings --env-file=.env.local src/seed.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^2.0.4",
    "@x402/core": "^2.17.0",
    "@x402/evm": "^2.17.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "viem": "^2.47.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "patch-package": "^8.0.1",
    "typescript": "^5.7.3"
  }
}
