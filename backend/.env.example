# ─────────────────────────────────────────────────────────────────────────────
# Assay backend secrets — copy this file to `backend/.env.local` and fill in real
# values. `backend/.env.local` is git-ignored; NEVER commit a real private key or
# paste it in chat. The npm scripts load it via `node --env-file=.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=4000
ASSAY_DB=data/assay.sqlite

# ── BUYER (the agent's paying wallet) ───────────────────────────────────────
# Funded Arc-testnet wallet that runs the real x402 → Gateway nanopayment flow.
# Fund it with testnet USDC before running with ASSAY_MOCK_PAY off.
BUYER_ADDRESS=0xREPLACE_WITH_YOUR_TESTNET_ADDRESS
BUYER_PRIVATE_KEY=0xREPLACE_WITH_YOUR_TESTNET_PRIVATE_KEY

# ── CREATOR (a seller wallet used for seeded demo sources) ──────────────────
# Where seeded-source payouts land so the payout ledger shows real per-creator USDC.
CREATOR_ADDRESS=0xREPLACE_WITH_A_TESTNET_ADDRESS
CREATOR_PRIVATE_KEY=0xREPLACE_WITH_A_TESTNET_PRIVATE_KEY

# How much USDC to deposit into the Gateway balance when it runs low (kept topped
# up so a batch of sub-cent buys never stalls mid-run).
DEPOSIT_AMOUNT=0.5
